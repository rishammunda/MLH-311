# Copy to .env and fill in. Never commit the real .env.

# Required — for the AI labeler (Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — a free Socrata app token raises SODA API rate limits.
# Register at https://data.sfgov.org (Developer Settings > App Tokens).
SF_APP_TOKEN=

# Optional tuning.
SEED_LIMIT=40            # cases pulled + labeled on startup
POLL_INTERVAL_SECONDS=60 # how often the background poller pulls fresh cases
# DISABLE_POLLER=1       # set to 1 to turn off background polling
# DATABASE_URL=          # for Raghav's Postgres store (DO Managed Postgres)
