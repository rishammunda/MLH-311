# Copy to .env and fill in. Never commit the real .env.

# Required — for the AI labeler AND the demo call extraction. A DigitalOcean
# Gradient AI *model access key* (create one in the DO console: Gradient AI
# Platform > Serverless Inference). Without it, both fall back to safe defaults.
DIGITALOCEAN_INFERENCE_KEY=

# Optional — override the model / endpoint used by the labeler + demo extraction.
# DO_MODEL=openai-gpt-oss-20b               # default; e.g. llama3.3-70b-instruct
# DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1

# Optional — a free Socrata app token raises SODA API rate limits.
# Register at https://data.sfgov.org (Developer Settings > App Tokens).
SF_APP_TOKEN=

# Optional tuning.
SEED_LIMIT=40            # cases pulled + labeled on startup
POLL_INTERVAL_SECONDS=60 # how often the background poller pulls fresh cases
# DISABLE_POLLER=1       # set to 1 to turn off background polling
# DATABASE_URL=sqlite:///./sf311.db # defaults to backend/sf311.db locally
# DATABASE_URL=postgresql://...     # injected by DO Managed Postgres in production
# ENABLE_SIMULATE_SURGE=1           # demo only; leave unset in production
